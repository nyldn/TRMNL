<div class="layout layout--col gap--large">
  <div class="grid grid--cols-2 gap--medium">
    <div>
      <span class="label label--small">{{ display_label | default: "Status" }}</span>
      <div class="value value--xxlarge">{{ headline | default: "Ready" }}</div>
      <div class="description">{{ summary | default: "Add a concise summary." }}</div>
    </div>
    <div class="item-list">
      {% for item in items limit: 4 %}
        <div class="item">
          <div class="meta"></div>
          <div class="content">
            <span class="title">{{ item.label }}</span>
            <span class="description">{{ item.value }}</span>
          </div>
        </div>
      {% else %}
        <div class="description">No items yet.</div>
      {% endfor %}
    </div>
  </div>
</div>

<div class="title_bar">
  <span class="title">{{ display_label | default: "TRMNL" }}</span>
  <span class="instance">{{ trmnl.plugin_settings.instance_name | default: "Recipe" }}</span>
</div>

